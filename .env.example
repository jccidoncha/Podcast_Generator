# AI providers
# OpenAI key is used for BOTH research (web_search agent) and script generation
# — see CLAUDE.md §2.4 + §2.7.
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# News sourcing — OPTIONAL fallback
# Default news sourcing is the OpenAI research agent (CLAUDE.md §2.4).
# Only set NEWS_API_KEY if you switch back to the legacy NewsAPI client in
# /src/providers/news.ts.
# NEWS_API_KEY=

# Database (Supabase Postgres — see CLAUDE.md §2.5)
#
# DATABASE_URL: transaction-mode pooler (port 6543). Append BOTH query params:
#   ?pgbouncer=true&connection_limit=1
# `pgbouncer=true` makes Prisma skip prepared statements (incompatible with
# transaction mode). `connection_limit=1` prevents stale connections in dev
# (P1017 "Server has closed the connection" errors). Example:
#   postgresql://<user>:<pwd>@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=
# DIRECT_URL: session-mode pooler (port 5432). Used by Prisma for migrations
# only — no pgbouncer/connection_limit params needed.
DIRECT_URL=

# Optional: only if/when BullMQ is introduced
# REDIS_URL=

# Optional: prod audio storage (S3-compatible)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Worker
WORKER_CRON="* * * * *"      # every minute — drives per-user schedule check
DRY_RUN=true                 # when true, providers return canned data — never call real APIs

# Logging
LOG_LEVEL=info
